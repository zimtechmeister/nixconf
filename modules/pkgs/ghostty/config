# Font Settings
font-family = "Maple Mono NF"
font-size = 12

# Window Options
window-padding-balance = true
shell-integration-features = ssh-terminfo, ssh-env

theme = "nixTheme"

# Allow local config & Noctalia themes to override settings here
config-file = ?~/.config/ghostty/auto/theme.ghostty
config-file = ?~/.config/ghostty/config.ghostty
